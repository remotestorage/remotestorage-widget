{
  "name": "remotestorage-widget",
  "version": "1.8.0",
  "description": "remoteStorage.js connect widget",
  "main": "build/widget.js",
  "scripts": {
    "start": "npm run dev",
    "clean": "rimraf build/*",
    "prebuild": "npm run clean -s",
    "build": "NODE_ENV=production webpack",
    "dev": "webpack serve",
    "open": "opener http://localhost:8008",
    "version": "npm run build && git add build/",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remotestorage/remotestorage-widget.git"
  },
  "keywords": [
    "remotestorage",
    "remotestoragejs",
    "unhosted",
    "no-backend",
    "offline-first"
  ],
  "author": "RS Contributors",
  "contributors": [],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/remotestorage/remotestorage-widget/issues"
  },
  "homepage": "https://github.com/remotestorage/remotestorage-widget#readme",
  "devDependencies": {
    "@babel/cli": "^7.26.2",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.1",
    "babel-loader": "^9.2.1",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "http-server": "^14.1.1",
    "opener": "^1.5.2",
    "raw-loader": "^4.0.2",
    "remotestoragejs": "2.0.0-beta.7",
    "rimraf": "^6.0.1",
    "svg-inline-loader": "^0.8.2",
    "typescript": "^5.7.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  }
}
