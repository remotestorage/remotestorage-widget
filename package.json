{
  "name": "remotestorage-widget",
  "version": "1.8.1",
  "description": "remoteStorage.js connect widget",
  "main": "build/widget.js",
  "scripts": {
    "start": "npm run dev",
    "clean": "rimraf --glob build/*",
    "prebuild": "npm run clean -s",
    "build": "NODE_ENV=production webpack",
    "dev": "webpack serve",
    "open": "opener http://localhost:8008",
    "version": "npm run build && git add build/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remotestorage/remotestorage-widget.git"
  },
  "keywords": [
    "remotestorage",
    "remotestoragejs",
    "unhosted",
    "no-backend",
    "offline-first"
  ],
  "author": "RS Contributors",
  "contributors": [],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/remotestorage/remotestorage-widget/issues"
  },
  "homepage": "https://github.com/remotestorage/remotestorage-widget#readme",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-loader": "^10.1.1",
    "html-loader": "^5.1.0",
    "http-server": "^14.1.1",
    "opener": "^1.5.2",
    "remotestoragejs": "2.0.0-beta.9",
    "rimraf": "^6.1.3",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
